<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sakura Raw</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{background:#0d0d0d;color:#e0e0e0;font-family:'Courier New',monospace;padding:20px}
.container{max-width:900px;margin:0 auto}
h1{color:#f8b4c8;font-size:2.5rem;text-align:center;padding:20px 0;border-bottom:1px solid #2a2a2a;margin-bottom:20px}
textarea{width:100%;min-height:200px;background:#111;border:1px solid #333;border-radius:6px;color:#e0e0e0;font-family:'Courier New',monospace;font-size:14px;padding:12px;resize:vertical;outline:none}
textarea:focus{border-color:#f8b4c8}
.row{display:flex;gap:10px;margin:10px 0;flex-wrap:wrap}
input{flex:1;min-width:150px;padding:10px 12px;background:#111;border:1px solid #333;border-radius:6px;color:#e0e0e0;font-family:'Courier New',monospace;font-size:14px;outline:none}
input:focus{border-color:#f8b4c8}
button{padding:10px 20px;border:none;border-radius:6px;font-family:'Courier New',monospace;font-size:14px;font-weight:bold;cursor:pointer;text-transform:uppercase}
.btn-save{background:#f8b4c8;color:#0d0d0d}
.btn-save:hover{background:#e090b0}
.btn-clear{background:#333;color:#e0e0e0}
.btn-clear:hover{background:#444}
.paste-item{background:#1a1a1a;border:1px solid #2a2a2a;border-radius:6px;padding:12px 16px;margin:8px 0;display:flex;justify-content:space-between;align-items:center}
.paste-name{color:#f8b4c8;font-weight:bold;font-size:1.1rem}
.raw-link{background:#2a2a2a;color:#f8b4c8;border:1px solid #f8b4c8;padding:5px 12px;border-radius:4px;font-size:12px;text-transform:uppercase;text-decoration:none;cursor:pointer;font-family:'Courier New',monospace}
.raw-link:hover{background:#f8b4c8;color:#0d0d0d}
.btn-del{background:transparent;border:1px solid #ff4d4d;color:#ff4d4d;padding:5px 12px;border-radius:4px;font-size:12px;cursor:pointer;margin-left:8px;font-family:'Courier New',monospace}
.btn-del:hover{background:#ff4d4d;color:white}
.actions{display:flex;gap:5px;align-items:center}
.info{color:#555;text-align:center;padding:20px;font-size:14px}
#toast{position:fixed;bottom:20px;right:20px;background:#1a1a1a;border:1px solid #f8b4c8;padding:12px 20px;border-radius:6px;color:#f8b4c8;font-size:13px;opacity:0;transition:all 0.3s;z-index:999}
#toast.show{opacity:1}
</style>
</head>
<body>
<div class="container">
<h1>SAKURA RAW</h1>
<textarea id="content" placeholder="Nhap script cua ban vao day..."></textarea>
<div class="row">
<input type="text" id="name" placeholder="Ten raw">
<button class="btn-save" onclick="save()">Luu</button>
<button class="btn-clear" onclick="clearForm()">Moi</button>
</div>
<div id="list"></div>
<div class="info">sakura raw — du lieu luu tren trinh duyet</div>
</div>
<div id="toast"></div>
<script>
var KEY='sakura_raws';
function all(){try{return JSON.parse(localStorage.getItem(KEY))||[]}catch(e){return[]}}
function saveAll(d){localStorage.setItem(KEY,JSON.stringify(d))}
function id8(){var c='abcdefghijklmnopqrstuvwxyz0123456789',r='';for(var i=0;i<8;i++){r+=c.charAt(Math.floor(Math.random()*c.length))}return r}
function msg(s){var t=document.getElementById('toast');t.textContent=s;t.classList.add('show');setTimeout(function(){t.classList.remove('show')},2500)}
function clearForm(){document.getElementById('content').value='';document.getElementById('name').value=''}
function save(){var c=document.getElementById('content').value.trim();var n=document.getElementById('name').value.trim();if(!c){msg('Nhap noi dung');return}if(!n){msg('Nhap ten raw');return}var d=all();var idx=-1;for(var i=0;i<d.length;i++){if(d[i].name===n){idx=i;break}}if(idx!==-1){d[idx].content=c;d[idx].updatedAt=new Date().toISOString()}else{d.push({id:id8(),name:n,content:c,createdAt:new Date().toISOString(),updatedAt:new Date().toISOString()})}saveAll(d);render();clearForm();msg('Da luu: '+n)}
function del(n){if(!confirm('Xoa "'+n+'"?'))return;var d=all();var r=[];for(var i=0;i<d.length;i++){if(d[i].name!==n){r.push(d[i])}}saveAll(r);render();msg('Da xoa: '+n)}
function openRaw(n){var d=all();var p=null;for(var i=0;i<d.length;i++){if(d[i].name===n){p=d[i];break}}if(!p){msg('Khong tim thay raw');return}var w=window.open('','_blank');var h='<!DOCTYPE html><html><head><meta charset="UTF-8"><title>'+p.name+' raw</title><style>body{background:#0d0d0d;color:#e0e0e0;font-family:Courier New,monospace;font-size:14px;padding:20px;white-space:pre-wrap;word-break:break-all}pre{margin:0}</style></head><body><pre>';
var esc=p.content.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
h+=esc;h+='</pre></body></html>';w.document.write(h);w.document.close()}
function handleRawRoute(){var params=new URLSearchParams(window.location.search);var rawName=params.get('raw');if(rawName){var d=all();var p=null;for(var i=0;i<d.length;i++){if(d[i].name===rawName){p=d[i];break}}if(p){var esc=p.content.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');document.body.innerHTML='<pre style="background:#0d0d0d;color:#e0e0e0;font-family:Courier New,monospace;font-size:14px;padding:20px;margin:0;white-space:pre-wrap;word-break:break-all;">'+esc+'</pre>';document.title=p.name+' raw'}else{document.body.innerHTML='<pre style="background:#0d0d0d;color:#ff4d4d;font-family:monospace;padding:20px;">404 — '+rawName+' khong ton tai</pre>';document.title='404 not found'}}}
function render(){var c=document.getElementById('list');var d=all();if(d.length===0){c.innerHTML='<div class="info">Chua co raw nao</div>';return}d.sort(function(a,b){return new Date(b.updatedAt)-new Date(a.updatedAt)});var html='';for(var i=0;i<d.length;i++){var p=d[i];var u=window.location.origin+window.location.pathname+'?raw='+encodeURIComponent(p.name);html+='<div class="paste-item"><div class="paste-name">'+p.name+'</div><div class="actions"><a href="'+u+'" target="_blank" class="raw-link">RAW</a><button class="btn-del" onclick="del(\''+p.name.replace(/'/g,"\\'")+'\')">Xoa</button></div></div>'}c.innerHTML=html}
if(window.location.search.includes('raw=')){handleRawRoute()}else{render()}
</script>
</body>
</html>
